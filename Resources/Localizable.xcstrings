  "strings" : {
    "accessibilityDialog.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MacDial needs Accessibility permissions to work properly. In the next dialog you will be asked to open the Settings app to enable the permissions.\n\nIf you keep seeing this message, click the help icon for assistance.\nComplete the actions shown in the help popup before clicking OK."
          }
        }
      }
    },
